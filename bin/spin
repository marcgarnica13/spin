#!/usr/bin/env bash
set -euo pipefail

# Resolve the real path of this script (works through symlinks)
SPIN_ROOT="$(cd "$(dirname "$(readlink -f "$0")")/.." && pwd)"

# Support both dev layout (lib/spin-common.sh) and installed layout (lib/spin/spin-common.sh)
if [[ -f "$SPIN_ROOT/lib/spin-common.sh" ]]; then
  SPIN_LIB="$SPIN_ROOT/lib"
elif [[ -f "$SPIN_ROOT/lib/spin/spin-common.sh" ]]; then
  SPIN_LIB="$SPIN_ROOT/lib/spin"
else
  echo "Error: Cannot find spin-common.sh (looked in $SPIN_ROOT/lib/ and $SPIN_ROOT/lib/spin/)" >&2
  exit 1
fi

# shellcheck source=../lib/spin-common.sh
source "$SPIN_LIB/spin-common.sh"

usage() {
  cat <<EOF
${BOLD}spin${RESET} v${SPIN_VERSION} — parallel Claude Code session manager

${BOLD}USAGE${RESET}
  spin claude <name1> [name2] ...    Launch Claude sessions in tmux worktrees
  spin status [--once]               Monitor active spin sessions
  spin connect [session]             Reconnect to an existing session

${BOLD}OPTIONS${RESET}
  -v, --version    Show version
  -h, --help       Show this help
EOF
}

case "${1:-}" in
  claude)
    shift
    [[ $# -eq 0 ]] && spin_die "usage: spin claude <name1> [name2] ..."
    # shellcheck source=../lib/spin-status.sh
    source "$SPIN_LIB/spin-status.sh"
    # shellcheck source=../lib/spin-status-daemon.sh
    source "$SPIN_LIB/spin-status-daemon.sh"
    # shellcheck source=../lib/spin-claude.sh
    source "$SPIN_LIB/spin-claude.sh"
    spin_claude "$@"
    ;;
  status)
    shift
    # shellcheck source=../lib/spin-status.sh
    source "$SPIN_LIB/spin-status.sh"
    spin_status "$@"
    ;;
  connect)
    shift
    # shellcheck source=../lib/spin-connect.sh
    source "$SPIN_LIB/spin-connect.sh"
    spin_connect "$@"
    ;;
  -v|--version)
    echo "spin $SPIN_VERSION"
    ;;
  -h|--help|"")
    usage
    ;;
  *)
    spin_die "unknown command: $1 (see spin --help)"
    ;;
esac
